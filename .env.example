# AMRIT AI Framework — Environment Variables
# Copy this to .env and fill in your values

# ─── GitHub ───────────────────────────────────────────────────────────────────
# Personal access token with read:repo scope for code-context-server
GITHUB_TOKEN=ghp_your_token_here
GITHUB_ORG=PSMRI

# ─── Confluence ───────────────────────────────────────────────────────────────
CONFLUENCE_BASE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_EMAIL=your@email.com
CONFLUENCE_API_TOKEN=your_confluence_api_token
# Space keys to index (comma-separated)
CONFLUENCE_SPACES=AMRIT,DEV,OPS

# ─── JIRA ─────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your_jira_api_token
# Project keys relevant to AMRIT (comma-separated)
JIRA_PROJECTS=AMRIT,MOB,INF

# ─── Docs Server ──────────────────────────────────────────────────────────────
# Where to store the built search index
AMRIT_DOCS_INDEX_PATH=./data/docs-index
# GitHub repos to index (comma-separated, org/repo format)
AMRIT_DOCS_REPOS=PSMRI/AMRIT,PSMRI/HWC-API,PSMRI/Helpline104-API,PSMRI/TM-API,PSMRI/MMU-API,PSMRI/AMRIT-Mobile

# ─── Server ports (for HTTP mode, not needed for stdio MCP) ───────────────────
DOCS_SERVER_PORT=3001
CONFLUENCE_SERVER_PORT=3002
JIRA_SERVER_PORT=3003
CODE_CONTEXT_SERVER_PORT=3004

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
